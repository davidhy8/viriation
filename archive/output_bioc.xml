 "pub-id_pmid": "33789084", "section_type": "REF", "source": "Cell Host Microbe", "type": "ref", "volume": "29", "year": "2021"}, "text": "Potent SARS-CoV-2 neutralizing antibodies directed against spike N-terminal domain target a single supersite", "sentences": [], "annotations": [], "relations": []}, {"offset": 30165, "infons": {"fpage": "650", "lpage": "655", "pub-id_doi": "10.1126/science.abc6952", "pub-id_pmid": "32571838", "section_type": "REF", "source": "Science", "type": "ref", "volume": "369", "year": "2020"}, "text": "A neutralizing human antibody binds to the N-terminal domain of the Spike protein of SARS-CoV-2", "sentences": [], "annotations": [], "relations": []}, {"offset": 30261, "infons": {"fpage": "616", "lpage": "622", "pub-id_doi": "10.1038/s41586-021-03324-6", "pub-id_pmid": "33567448", "section_type": "REF", "source": "Nature", "type": "ref", "volume": "592", "year": "2021"}, "text": "mRNA vaccine-elicited antibodies to SARS-CoV-2 and circulating variants", "sentences": [], "annotations": [], "relations": []}, {"offset": 30333, "infons": {"fpage": "682", "lpage": "687", "pub-id_doi": "10.1038/s41586-020-2852-1", "pub-id_pmid": "33045718", "section_type": "REF", "source": "Nature", "type": "ref", "volume": "588", "year": "2020"}, "text": "SARS-CoV-2 neutralizing antibody structures inform therapeutic strategies", "sentences": [], "annotations": [], "relations": []}, {"offset": 30407, "infons": {"fpage": "437", "lpage": "442", "pub-id_doi": "10.1038/s41586-020-2456-9", "pub-id_pmid": "32555388", "section_type": "REF", "source": "Nature", "type": "ref", "volume": "584", "year": "2020"}, "text": "Convergent antibody responses to SARS-CoV-2 in convalescent individuals", "sentences": [], "annotations": [], "relations": []}, {"offset": 30479, "infons": {"elocation-id": "eabf1906", "pub-id_doi": "10.1126/scitranslmed.abf1906", "pub-id_pmid": "33820835", "section_type": "REF", "source": "Sci. Transl. Med.", "type": "ref", "volume": "13", "year": "2020"}